---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
  description: string;
  heroTitle: string;
  heroSubtitle: string;
  keywords?: string;
  breadcrumbTitle?: string;
  breadcrumbParent?: string;
  breadcrumbParentUrl?: string;
  relatedServices?: Array<{ title: string; href: string; desc: string }>;
}

const {
  title,
  description,
  heroTitle,
  heroSubtitle,
  keywords,
  breadcrumbTitle = '',
  breadcrumbParent = 'Services',
  breadcrumbParentUrl = '/services',
  relatedServices = [],
} = Astro.props;

const crumbTitle = breadcrumbTitle || title.split('|')[0].trim();

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "LegalService",
  "name": title,
  "description": description,
  "provider": {
    "@type": "Attorney",
    "name": "Mesa Estate Planning PLLC",
    "url": "https://www.mesaestateplanninglawyer.com"
  },
  "areaServed": { "@type": "State", "name": "Arizona" },
  "url": Astro.url.href,
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.mesaestateplanninglawyer.com" },
    { "@type": "ListItem", "position": 2, "name": breadcrumbParent, "item": "https://www.mesaestateplanninglawyer.com" + breadcrumbParentUrl },
    { "@type": "ListItem", "position": 3, "name": crumbTitle }
  ]
};
---

<BaseLayout title={title} description={description} keywords={keywords} schema={serviceSchema}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <section class="service-hero">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="breadcrumb-sep">/</span>
      <a href={breadcrumbParentUrl}>{breadcrumbParent}</a>
      <span class="breadcrumb-sep">/</span>
      <span class="breadcrumb-current">{crumbTitle}</span>
    </nav>
    <div class="service-hero-content">
      <h1 class="hero-h1" style="opacity:1;animation:none;">{heroTitle}</h1>
      <p class="hero-body" style="opacity:1;animation:none;">{heroSubtitle}</p>
      <div class="hero-btns" style="opacity:1;animation:none;">
        <a href="/contact" class="btn-bronze">Book Free Consultation</a>
        <a href="tel:4800000000" class="btn-ghost-w">Call (480) 000-0000</a>
      </div>
    </div>
  </section>

  <section class="service-content">
    <slot />
  </section>

  {relatedServices.length > 0 && (
    <section class="related-services">
      <div class="section-label">Related Services</div>
      <h2 class="section-title">You may also need</h2>
      <div class="related-grid">
        {relatedServices.map(svc => (
          <a href={svc.href} class="service-card">
            <h3>{svc.title}</h3>
            <p>{svc.desc}</p>
            <span class="svc-link">Learn more</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <div class="cta-band">
    <div class="cta-band-content">
      <h2>Ready to get started?</h2>
      <p>Book a free 30-minute consultation — no obligation, just clarity.</p>
      <div class="cta-band-actions">
        <a href="/contact" class="btn-white">Book Free Consultation</a>
        <span class="cta-band-sub">Or call us at (480) 000-0000</span>
      </div>
    </div>
  </div>
</BaseLayout>
