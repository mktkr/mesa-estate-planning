<script>
// Tab switching
function switchTab(id) {
  document.querySelectorAll('.svc-tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.svc-panel').forEach(p => p.classList.remove('active'));
  document.getElementById('panel-' + id).classList.add('active');
  event.target.classList.add('active');
}

// FAQ toggle
function toggleFaq(btn) {
  const item = btn.closest('.faq-item');
  const isOpen = item.classList.contains('open');
  document.querySelectorAll('.faq-item.open').forEach(el => el.classList.remove('open'));
  if (!isOpen) item.classList.add('open');
}

// Segments scroll: dot tracking + hint fade
const segScroll = document.getElementById('segmentsScroll');
const segDots = document.querySelectorAll('#segmentDots .scroll-dot');
const scrollHint = document.querySelector('.scroll-hint');
let hintHidden = false;

if (segScroll) {
  segScroll.addEventListener('scroll', () => {
    if (!hintHidden && segScroll.scrollLeft > 20) {
      scrollHint.style.transition = 'opacity 0.4s';
      scrollHint.style.opacity = '0';
      setTimeout(() => { scrollHint.style.display = 'none'; }, 400);
      hintHidden = true;
    }
    const cards = segScroll.querySelectorAll('.segment-card');
    const scrollCenter = segScroll.scrollLeft + segScroll.clientWidth / 2;
    let activeIdx = 0;
    cards.forEach((card, i) => {
      const cardCenter = card.offsetLeft + card.offsetWidth / 2;
      if (Math.abs(cardCenter - scrollCenter) < card.offsetWidth / 2) activeIdx = i;
    });
    segDots.forEach((dot, i) => dot.classList.toggle('active', i === activeIdx));
  }, { passive: true });
}

// Resource filter buttons
const filterBtns = document.querySelectorAll('#resourceFilters .filter-btn');
const resourceCards = document.querySelectorAll('#resourceCards .resource-card');
const seeMoreCard = document.getElementById('resourceSeeMore');
const MAX_VISIBLE = 3;

function applyResourceFilter(filter) {
  const matching = [];
  const hidden = [];
  resourceCards.forEach(card => {
    const category = card.dataset.category;
    const matches = filter === 'all' || category === filter;
    if (matches) matching.push(card);
    else hidden.push(card);
  });
  hidden.forEach(card => {
    card.classList.remove('filter-visible');
    card.classList.add('filter-hidden', 'overflow-hidden');
    card.style.display = 'none';
  });
  matching.forEach((card, i) => {
    if (i < MAX_VISIBLE) {
      card.classList.remove('filter-hidden', 'overflow-hidden');
      card.classList.add('filter-visible');
      card.style.display = '';
    } else {
      card.classList.remove('filter-visible');
      card.classList.add('overflow-hidden');
      card.style.display = 'none';
    }
  });
  if (seeMoreCard) seeMoreCard.style.display = '';
}

if (filterBtns.length) {
  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter;
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      applyResourceFilter(filter);
    });
  });
  applyResourceFilter('all');
}

// Video lightbox
const videoTrigger = document.getElementById('videoTrigger');
const videoModal = document.getElementById('videoModal');
const videoClose = document.getElementById('videoClose');
if (videoTrigger && videoModal) {
  videoTrigger.addEventListener('click', () => {
    videoModal.classList.add('open');
    document.body.style.overflow = 'hidden';
  });
  videoClose.addEventListener('click', () => {
    videoModal.classList.remove('open');
    document.body.style.overflow = '';
  });
  videoModal.addEventListener('click', (e) => {
    if (e.target === videoModal) {
      videoModal.classList.remove('open');
      document.body.style.overflow = '';
    }
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && videoModal.classList.contains('open')) {
      videoModal.classList.remove('open');
      document.body.style.overflow = '';
    }
  });
}
</script>

