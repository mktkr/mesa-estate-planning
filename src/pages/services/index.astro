---
import BaseLayout from '../../layouts/BaseLayout.astro';
const trustsServices = [
  { title: 'Wills & Trusts', desc: 'Revocable living trusts, irrevocable trusts, and pour-over wills designed to avoid probate and protect beneficiaries.', href: '/services/wills-and-trusts', icon: '📜' },
  { title: 'Powers of Attorney', desc: 'Durable financial POA and healthcare directives that ensure your wishes are honored if incapacitated.', href: '/services/financial-power-of-attorney', icon: '✍️' },
  { title: 'Healthcare Directive', desc: 'Name a healthcare agent and record your wishes about medical treatment.', href: '/services/healthcare-directive', icon: '🏥' },
  { title: 'Asset Protection', desc: 'LLCs, domestic asset protection trusts, and strategic titling to shield your wealth from creditors.', href: '/services/asset-protection', icon: '🛡️' },
  { title: 'Estate Tax Planning', desc: 'Gifting strategies, dynasty trusts, and estate tax minimization for significant assets.', href: '/services/estate-tax-planning', icon: '📊' },
  { title: 'Charitable Planning', desc: 'Charitable remainder trusts, donor-advised funds, and philanthropic strategies for family and community.', href: '/services/charitable-planning', icon: '🤝' },
];
const businessServices = [
  { title: 'Business Succession', desc: 'Buy-sell agreements and succession plans for smooth business transitions.', href: '/services/business-succession-planning', icon: '🏢' },
  { title: 'Business Formation', desc: 'LLC formation, S-corp elections, and entity structuring that protects personal assets.', href: '/services/business-formation', icon: '⚖️' },
  { title: 'Commercial Lease Review', desc: 'Thorough review of terms, exclusives, and exit provisions in lease negotiations.', href: '/services/commercial-lease-review', icon: '📋' },
];
---
<BaseLayout
  title="Estate Planning Services | Mesa, AZ | Mesa Estate Planning"
  description="Comprehensive estate planning services for Arizona families and business owners. Wills, trusts, asset protection, business succession, tax planning, and more."
  keywords="estate planning services mesa az, wills trusts arizona, asset protection, business succession planning"
>
  <section class="services-index-hero">
    <div class="services-index-hero-content">
      <div class="hero-eyebrow" style="opacity:1;animation:none;">Our Services</div>
      <h1 class="hero-h1" style="opacity:1;animation:none;">The right plan for <em>your</em> situation</h1>
      <p class="hero-body" style="opacity:1;animation:none;">Every family and business is different. We help you understand exactly which documents you need, why you need them, and what they do for you.</p>
      <div class="hero-btns" style="opacity:1;animation:none;">
        <a href="#contact" class="btn-bronze">Book Free Consultation</a>
        <a href="tel:4800000000" class="btn-ghost-w">Call (480) 000-0000</a>
      </div>
    </div>
  </section>
  <section class="services-index-grid">
    <div class="services-index-section">
      <div class="services-index-label">Trusts and Estates</div>
      <div class="services-card-grid">
        {trustsServices.map(svc => (
          <a href={svc.href} class="services-index-card">
            <div class="services-card-icon">{svc.icon}</div>
            <h3>{svc.title}</h3>
            <p>{svc.desc}</p>
            <span class="services-card-link">Learn more &rarr;</span>
          </a>
        ))}
      </div>
    </div>
    <div class="services-index-section">
      <div class="services-index-label">Business and Tax</div>
      <div class="services-card-grid">
        {businessServices.map(svc => (
          <a href={svc.href} class="services-index-card">
            <div class="services-card-icon">{svc.icon}</div>
            <h3>{svc.title}</h3>
            <p>{svc.desc}</p>
            <span class="services-card-link">Learn more &rarr;</span>
          </a>
        ))}
      </div>
    </div>
    <div class="services-index-cta">
      <h2>Not sure what you need?</h2>
      <p>Most clients don't know exactly which documents they need before their first meeting. Start with a <a href="/our-process">free consultation</a> and we will walk you through it.</p>
      <a href="#contact" class="btn-bronze">Book Free Consultation</a>
    </div>
  </section>
  <style>
    .services-index-hero{padding:calc(56px + 48px) var(--page-px, 20px) 48px;background:var(--sage);position:relative;overflow:hidden;text-align:center;}
    .services-index-hero::before{content:'';position:absolute;inset:0;pointer-events:none;background:radial-gradient(ellipse 80% 60% at 30% 30%,rgba(255,255,255,0.08) 0%,transparent 60%),radial-gradient(ellipse 50% 50% at 80% 80%,rgba(74,99,87,0.5) 0%,transparent 50%);}
    .services-index-hero-content{position:relative;z-index:1;max-width:640px;margin:0 auto;}
    .services-index-hero .hero-h1{font-size:clamp(1.8rem,5.5vw,2.6rem);line-height:1.14;}
    .services-index-grid{max-width:1080px;margin:0 auto;padding:48px var(--page-px, 20px) 60px;}
    .services-index-section{margin-bottom:48px;}
    .services-index-label{font-size:0.6rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--sage);font-weight:600;margin-bottom:20px;display:flex;align-items:center;gap:10px;}
    .services-index-label::after{content:'';flex:1;height:1px;background:var(--sand);}
    .services-card-grid{display:grid;grid-template-columns:1fr;gap:16px;}
    .services-index-card{display:block;padding:28px 24px;background:white;border:1px solid var(--sand);border-radius:4px;text-decoration:none;transition:border-color 0.25s,box-shadow 0.25s;}
    .services-index-card:hover{border-color:var(--sage);box-shadow:0 4px 20px rgba(0,0,0,0.06);}
    .services-card-icon{font-size:1.5rem;margin-bottom:12px;}
    .services-index-card h3{font-family:var(--serif);font-size:1.1rem;font-weight:400;color:var(--charcoal);margin-bottom:8px;}
    .services-index-card p{font-size:0.82rem;color:var(--mid-gray);line-height:1.6;font-weight:300;margin-bottom:12px;}
    .services-card-link{font-size:0.68rem;letter-spacing:0.06em;text-transform:uppercase;color:var(--sage);font-weight:500;}
    .services-index-card:hover .services-card-link{color:var(--sage-dark);}
    .services-index-cta{text-align:center;padding:48px 24px;background:var(--sage-light);border-radius:6px;}
    .services-index-cta h2{font-family:var(--serif);font-size:1.4rem;font-weight:300;color:var(--charcoal);margin-bottom:12px;}
    .services-index-cta p{font-size:0.85rem;color:var(--mid-gray);line-height:1.7;font-weight:300;max-width:520px;margin:0 auto 24px;}
    @media(min-width:640px){.services-card-grid{grid-template-columns:repeat(2,1fr);}}
    @media(min-width:1024px){.services-card-grid{grid-template-columns:repeat(3,1fr);}.services-index-hero{padding-top:calc(68px + 80px);padding-bottom:72px;}}
  </style>
</BaseLayout>
