---
import BaseLayout from '../../layouts/BaseLayout.astro';
const articles = [
  {
    title: 'Does Every Arizona Family Need a Living Trust?',
    desc: 'We break down when a trust makes sense, what it costs, and why Arizona\'s probate process makes this decision critical.',
    href: '/blog/arizona-family-living-trust',
    category: 'Trusts',
    readTime: '8 min read',
    date: 'March 2025',
  },
];
---
<BaseLayout
  title="Estate Planning Articles & Guides | Mesa, AZ | Mesa Estate Planning"
  description="Plain-English articles, guides, and resources on Arizona estate planning, trusts, wills, business succession, asset protection, and tax planning. Free resources from Mesa Estate Planning."
  keywords="arizona estate planning articles, living trust guide arizona, estate planning resources mesa az"
>
  <section class="services-index-hero">
    <div class="services-index-hero-content">
      <div class="hero-eyebrow" style="opacity:1;animation:none;">Resources</div>
      <h1 class="hero-h1" style="opacity:1;animation:none;">Plain-English guides to <em>Arizona estate planning</em></h1>
      <p class="hero-body" style="opacity:1;animation:none;">No jargon. No fluff. Just clear answers to the questions our clients ask most often — written by the attorneys who handle these issues every day.</p>
    </div>
  </section>
  <section class="services-index-grid">
    <div class="services-index-section">
      <div class="services-index-label">Articles & Guides</div>
      <div class="services-card-grid">
        {articles.map(a => (
          <a href={a.href} class="services-index-card">
            <div style="display:flex;gap:8px;margin-bottom:12px;">
              <span style="font-size:0.65rem;letter-spacing:0.08em;text-transform:uppercase;color:var(--sage);font-weight:600;">{a.category}</span>
              <span style="font-size:0.65rem;color:var(--mid-gray);">&middot;</span>
              <span style="font-size:0.65rem;color:var(--mid-gray);">{a.readTime}</span>
            </div>
            <h3>{a.title}</h3>
            <p>{a.desc}</p>
            <span class="services-card-link">Read article &rarr;</span>
          </a>
        ))}
      </div>
    </div>
    <div class="services-index-cta">
      <h2>Have a question we haven't covered?</h2>
      <p>We're always adding new articles based on what our clients ask. In the meantime, a free consultation is the fastest way to get a clear answer to your specific situation.</p>
      <a href="#contact" class="btn-bronze">Book Free Consultation</a>
    </div>
  </section>
</BaseLayout>
