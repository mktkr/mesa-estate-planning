---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Our Team | Mesa Estate Planning Attorneys | Mesa, AZ"
  description="Meet the attorneys at Mesa Estate Planning — J. McKay Tucker, Esq. and Of Counsel Jay Allen, Esq. Mesa-born, nationally trained, locally committed."
  keywords="mesa estate planning attorneys, estate planning lawyer mesa az, mckay tucker attorney, jay allen attorney mesa"
>
  <section class="services-index-hero">
    <div class="services-index-hero-content">
      <div class="hero-eyebrow" style="opacity:1;animation:none;">About</div>
      <h1 class="hero-h1" style="opacity:1;animation:none;">Mesa roots. <em>National-caliber</em> estate planning.</h1>
      <p class="hero-body" style="opacity:1;animation:none;">Mesa Estate Planning was built on a simple idea: every family deserves the kind of thoroughness and attention that most firms reserve for their wealthiest clients.</p>
    </div>
  </section>

  <section class="services-index-grid">
    <div class="services-index-section">
      <div class="services-index-label">Our Attorneys</div>
      <div class="services-card-grid">
        <a href="/about/mckay-tucker" class="services-index-card">
          <span style="font-size:0.65rem;letter-spacing:0.08em;text-transform:uppercase;color:var(--sage);font-weight:600;">Founder</span>
          <h3>J. McKay Tucker, Esq.</h3>
          <p>Born and raised in Mesa. BYU Economics, ASU Law. Trained at one of the most sophisticated estate planning practices in the country before coming home to build this firm for the community he grew up in.</p>
          <span class="services-card-link">Full bio &rarr;</span>
        </a>
        <a href="/about/jay-allen" class="services-index-card">
          <span style="font-size:0.65rem;letter-spacing:0.08em;text-transform:uppercase;color:var(--sage);font-weight:600;">Of Counsel</span>
          <h3>Jay Allen, Esq.</h3>
          <p>Nearly three decades of Arizona estate planning and business law experience. Born and raised in Mesa, still serving the community he's called home his entire career.</p>
          <span class="services-card-link">Full bio &rarr;</span>
        </a>
      </div>
    </div>

    <div class="services-index-section">
      <div class="services-index-label">How We Work</div>
      <div class="services-card-grid">
        <a href="/our-process" class="services-index-card">
          <h3>Our Process</h3>
          <p>From free consultation to signed documents and funded trust — a five-step process designed around your situation, not a template.</p>
          <span class="services-card-link">Learn about our process &rarr;</span>
        </a>
        <a href="/pricing" class="services-index-card">
          <h3>Pricing</h3>
          <p>All work is flat-fee, quoted after the free consultation. You know the total cost before you commit to anything.</p>
          <span class="services-card-link">See pricing details &rarr;</span>
        </a>
      </div>
    </div>

    <div class="services-index-cta">
      <h2>Ready to meet us?</h2>
      <p>The best way to see if we're the right fit is a free consultation. No pressure, no commitment — just a conversation about your situation.</p>
      <a href="/contact" class="btn-bronze">Book Free Consultation</a>
    </div>
  </section>
</BaseLayout>
