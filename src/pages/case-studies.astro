---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Case Studies | Real Estate Planning Scenarios | Mesa Estate Planning"
  description="Real estate planning scenarios explained — how Arizona families and business owners solved common challenges with trusts, asset protection, and succession planning."
  keywords="estate planning case studies, trust case study arizona, asset protection example, business succession case study"
>
  <section class="services-index-hero">
    <div class="services-index-hero-content">
      <div class="hero-eyebrow" style="opacity:1;animation:none;">Resources</div>
      <h1 class="hero-h1" style="opacity:1;animation:none;">Real scenarios, <em>explained</em></h1>
      <p class="hero-body" style="opacity:1;animation:none;">Anonymized case studies showing how Arizona families and business owners addressed real estate planning challenges — and what you can learn from their situations.</p>
    </div>
  </section>

  <section class="services-index-grid">
    <div class="services-index-section">
      <div class="services-index-label">Coming Soon</div>
      <div class="services-card-grid">
        <div class="services-index-card" style="opacity:0.65;">
          <span style="font-size:0.65rem;letter-spacing:0.08em;text-transform:uppercase;color:var(--bronze);font-weight:600;">Coming Soon</span>
          <h3>Case studies are on the way</h3>
          <p>We're putting together detailed, anonymized walkthroughs of real client situations — covering trusts, asset protection, business succession, and more. Check back soon.</p>
        </div>
      </div>
    </div>

    <div class="services-index-cta">
      <h2>Have a situation you'd like to discuss?</h2>
      <p>Every case study starts with a conversation. Book a free consultation and we'll help you think through your specific circumstances.</p>
      <a href="/contact" class="btn-bronze">Book Free Consultation</a>
    </div>
  </section>
</BaseLayout>
